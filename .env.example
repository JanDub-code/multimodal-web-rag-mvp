APP_NAME=Local Multimodal MVP
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/multimodal_mvp
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=chunks_qwen3_embedding_8b_4096

EMBEDDING_BASE_URL=http://127.0.0.1:11434
# Docker-only override for api/migrate services.
# Use http://host.docker.internal:11434 when the app runs in Docker and Ollama runs on the host.
DOCKER_EMBEDDING_BASE_URL=
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIMENSIONS=4096
EMBEDDING_TIMEOUT_SECONDS=60
LLM_BASE_URL=http://127.0.0.1:1234/v1
# Docker-only override for api/migrate services.
# Use http://host.docker.internal:1234/v1 when the app runs in Docker and LM Studio runs on the host.
DOCKER_LLM_BASE_URL=
LLM_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3.5-2b
LLM_VISION_MODEL=qwen/qwen3.5-2b
VISION_ANSWER_ENABLED=true
VISION_EXTRACT_ON_INGEST=true
VISION_MAX_IMAGES=2
VISION_TIMEOUT_SECONDS=90
VISION_PROMPT_MAX_CONTEXT_CHARS=3000
FETCH_VERIFY_SSL=true

EVIDENCE_DIR=./data/evidence
SCREENSHOT_DIR=./data/evidence/screenshots
DOM_SNAPSHOT_DIR=./data/evidence/dom

ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=43200
QUALITY_THRESHOLD_CHARS=300
RETRIEVAL_MIN_SCORE=0.25
COMPLIANCE_ENFORCEMENT=false

# Refresh scheduler (URL re-ingest)
REFRESH_DEFAULT_INTERVAL_MINUTES=10080
REFRESH_RETRY_BACKOFF_MINUTES=30
REFRESH_SCHEDULER_ENABLED=false
REFRESH_SCHEDULER_INTERVAL_SECONDS=900
REFRESH_SCHEDULER_BATCH_SIZE=5
